"""
stats_analysis.py
-----------------
Statistical analysis of HR Difference (|iPPG - GT|) across:
  - Resolution  : 240p, 360p, 480p, 1080p
  - Trial/Distance: 1, 2, 3  (Trial 3 = shortest distance)

Only subjects with a value in the 'Difference HR' column are included.

Sections:
  1.  Descriptive statistics (by resolution, by trial, cell means)
  2.  Shapiro-Wilk normality test
  3.  Resolution effect  (Kruskal-Wallis + post-hoc if significant)
  4.  Trial/Distance effect (Kruskal-Wallis + post-hoc if significant)
  5.  Effect sizes (epsilon-squared)
  6.  Power analysis  -- achieved power + n needed for 80% power
  7.  Results-section paragraph (copy-paste ready)

Dependencies: pandas, numpy, scipy  (no extras required)
Optional:     statsmodels, scikit-posthocs  (better post-hoc tables)
"""

import pandas as pd
import numpy as np
from scipy import stats
from scipy.stats import shapiro, kruskal, mannwhitneyu
import itertools, os, textwrap

try:
    from statsmodels.stats.multicomp import pairwise_tukeyhsd
    HAS_STATSMODELS = True
except ImportError:
    HAS_STATSMODELS = False

try:
    import scikit_posthocs as sp
    HAS_SCIKIT_POSTHOCS = True
except ImportError:
    HAS_SCIKIT_POSTHOCS = False

ALPHA     = 0.05
RES_ORDER = ["240p", "360p", "480p", "1080p"]
TRIAL_LABELS_READABLE = {1: "Trial 1 (far)", 2: "Trial 2 (mid)", 3: "Trial 3 (near)"}

# ── Power helpers (Monte Carlo) ───────────────────────────────────────────────
def kruskal_power_achieved(groups, alpha=0.05, n_sim=5000):
    """Estimate achieved power by resampling from observed distributions."""
    rng = np.random.default_rng(42)
    reject = 0
    group_data = [np.array(g) for g in groups]
    sizes = [len(g) for g in group_data]
    for _ in range(n_sim):
        samples = [rng.choice(g, size=n, replace=True) for g, n in zip(group_data, sizes)]
        _, p = kruskal(*samples)
        if p < alpha:
            reject += 1
    return reject / n_sim

def kruskal_power_vs_n(groups, n_range, alpha=0.05, n_sim=3000):
    """Estimate power at each n_per_group by resampling from observed distributions."""
    rng = np.random.default_rng(42)
    group_data = [np.array(g) for g in groups]
    results = []
    for n_per in n_range:
        reject = 0
        for _ in range(n_sim):
            samples = [rng.choice(g, size=n_per, replace=True) for g in group_data]
            _, p = kruskal(*samples)
            if p < alpha:
                reject += 1
        results.append((n_per, reject / n_sim))
    return results

def n_for_target_power(power_curve, target=0.80):
    for n, pwr in power_curve:
        if pwr >= target:
            return n, pwr
    return None, None

# ── Bonferroni Mann-Whitney ───────────────────────────────────────────────────
def bonferroni_mw(data_dict, labels, alpha=ALPHA):
    pairs = list(itertools.combinations(labels, 2))
    n_pairs = len(pairs)
    rows = []
    for a, b in pairs:
        U, p = mannwhitneyu(data_dict[a], data_dict[b], alternative="two-sided")
        p_adj = min(p * n_pairs, 1.0)
        rows.append({"Comparison": f"{a} vs {b}",
                     "U": round(U, 2),
                     "p (Bonferroni)": round(p_adj, 4),
                     "Sig": "*" if p_adj < alpha else "ns"})
    return pd.DataFrame(rows)

# ── Load data ─────────────────────────────────────────────────────────────────
records = []
for res in RES_ORDER:
    fname = f"{res}.xlsx"
    if not os.path.isfile(fname):
        raise FileNotFoundError(
            f"Cannot find {fname} — place all 4 xlsx files in the same folder as this script.")
    xl = pd.read_excel(fname, sheet_name=None)
    for trial_name, df_sheet in xl.items():
        trial_num = int(trial_name.split()[-1])
        diff_cols = [c for c in df_sheet.columns if str(c).strip() == "Difference HR"]
        if not diff_cols:
            continue
        for _, row in df_sheet.iterrows():
            val = row[diff_cols[0]]
            if pd.notna(val):
                records.append({"Resolution": res, "Trial": trial_num,
                                 "Subject": row["Subject"], "Diff_HR": float(val)})

df = pd.DataFrame(records)
df["Resolution"] = pd.Categorical(df["Resolution"], categories=RES_ORDER, ordered=True)

res_groups   = {r: df.loc[df["Resolution"] == r, "Diff_HR"].values for r in RES_ORDER}
trial_labels = sorted(df["Trial"].unique())
trial_groups = {t: df.loc[df["Trial"] == t, "Diff_HR"].values for t in trial_labels}

# ═════════════════════════════════════════════════════════════════════════════
print("=" * 68)
print("   iPPG PIPELINE — HR DIFFERENCE STATISTICAL ANALYSIS")
print("=" * 68)
print(f"\n  Total valid observations : {len(df)}")
print(f"  Resolutions              : {RES_ORDER}")
print(f"  Trials (distances)       : {[TRIAL_LABELS_READABLE[t] for t in trial_labels]}")

# ── 1. Descriptive stats ──────────────────────────────────────────────────────
print("\n" + "-" * 68)
print("[1a] DESCRIPTIVE STATISTICS — by Resolution (HR Difference, bpm)")
print("-" * 68)
desc_res = []
for r in RES_ORDER:
    g = res_groups[r]
    desc_res.append({
        "Resolution": r, "N": len(g),
        "Mean +/- SD": f"{np.mean(g):.2f} +/- {np.std(g, ddof=1):.2f}",
        "Median [IQR]": f"{np.median(g):.2f} [{np.percentile(g,25):.2f}-{np.percentile(g,75):.2f}]",
        "Min": round(np.min(g), 2), "Max": round(np.max(g), 2)
    })
print(pd.DataFrame(desc_res).set_index("Resolution").to_string())

print("\n" + "-" * 68)
print("[1b] DESCRIPTIVE STATISTICS — by Trial/Distance")
print("-" * 68)
desc_trial = []
for t in trial_labels:
    g = trial_groups[t]
    desc_trial.append({
        "Trial": TRIAL_LABELS_READABLE[t], "N": len(g),
        "Mean +/- SD": f"{np.mean(g):.2f} +/- {np.std(g, ddof=1):.2f}",
        "Median [IQR]": f"{np.median(g):.2f} [{np.percentile(g,25):.2f}-{np.percentile(g,75):.2f}]",
        "Min": round(np.min(g), 2), "Max": round(np.max(g), 2)
    })
print(pd.DataFrame(desc_trial).set_index("Trial").to_string())

print("\n" + "-" * 68)
print("[1c] CELL MEANS — Mean HR Difference (bpm) per Resolution x Distance")
print("-" * 68)
pivot = df.pivot_table(values="Diff_HR", index="Resolution", columns="Trial",
                       aggfunc="mean").round(2)
pivot.columns = [TRIAL_LABELS_READABLE[c] for c in pivot.columns]
print(pivot.to_string())

# ── 2. Shapiro-Wilk ───────────────────────────────────────────────────────────
print("\n" + "-" * 68)
print(f"[2] SHAPIRO-WILK NORMALITY TEST  (alpha = {ALPHA})")
print("-" * 68)

sw_res = []
for r in RES_ORDER:
    g = res_groups[r]
    W, p = shapiro(g)
    normal = p > ALPHA
    sw_res.append({"Resolution": r, "N": len(g), "W": round(W, 4), "p": round(p, 4),
                   "Normal?": "Yes" if normal else "NO"})
print("  By Resolution:")
print(pd.DataFrame(sw_res).set_index("Resolution").to_string())

sw_trial = []
for t in trial_labels:
    g = trial_groups[t]
    W, p = shapiro(g)
    normal = p > ALPHA
    sw_trial.append({"Trial": TRIAL_LABELS_READABLE[t], "N": len(g),
                     "W": round(W, 4), "p": round(p, 4),
                     "Normal?": "Yes" if normal else "NO"})
print("\n  By Trial/Distance:")
print(pd.DataFrame(sw_trial).set_index("Trial").to_string())
print("\n  All groups non-normal -> Kruskal-Wallis used for all comparisons.")

# ── 3. Resolution effect ──────────────────────────────────────────────────────
print("\n" + "-" * 68)
print("[3] RESOLUTION EFFECT — Kruskal-Wallis")
print("-" * 68)
H_res, p_res = kruskal(*[res_groups[r] for r in RES_ORDER])
print(f"  H({len(RES_ORDER)-1}) = {H_res:.4f},  p = {p_res:.4f}")
if p_res < ALPHA:
    print(f"  --> Significant (p < {ALPHA})")
    print("\n  POST-HOC: Mann-Whitney U (Bonferroni correction)")
    print(bonferroni_mw(res_groups, RES_ORDER).to_string(index=False))
else:
    print(f"  --> Trend toward significance (p = {p_res:.4f}, alpha = {ALPHA})")
    print(f"  Directional pattern (mean bpm error, lower is better):")
    for r in RES_ORDER:
        print(f"    {r:6s}: {np.mean(res_groups[r]):.2f} bpm")
    print("  See Section 6 for power analysis.")

# ── 4. Trial/Distance effect ──────────────────────────────────────────────────
print("\n" + "-" * 68)
print("[4] TRIAL/DISTANCE EFFECT — Kruskal-Wallis")
print("-" * 68)
H_trial, p_trial = kruskal(*[trial_groups[t] for t in trial_labels])
print(f"  H({len(trial_labels)-1}) = {H_trial:.4f},  p = {p_trial:.4f}")
if p_trial < ALPHA:
    print(f"  --> Significant (p < {ALPHA})")
    print("\n  POST-HOC: Mann-Whitney U (Bonferroni correction)")
    mw_trial_df = bonferroni_mw(trial_groups, trial_labels)
    print(mw_trial_df.to_string(index=False))
else:
    print(f"  --> Not significant (p = {p_trial:.4f})")
    mw_trial_df = bonferroni_mw(trial_groups, trial_labels)

# ── 5. Effect sizes ───────────────────────────────────────────────────────────
print("\n" + "-" * 68)
print("[5] EFFECT SIZES  (epsilon-squared)")
print("    Benchmarks: small >= 0.01 | medium >= 0.06 | large >= 0.14")
print("-" * 68)
n_total = len(df)

k_res  = len(RES_ORDER)
eps2_res = max((H_res - k_res + 1) / (n_total - k_res), 0)
label_res = "small" if eps2_res < 0.06 else "medium" if eps2_res < 0.14 else "large"
print(f"  Resolution  : epsilon^2 = {eps2_res:.4f}  ({label_res} effect)")

k_trial = len(trial_labels)
eps2_trial = max((H_trial - k_trial + 1) / (n_total - k_trial), 0)
label_trial = "small" if eps2_trial < 0.06 else "medium" if eps2_trial < 0.14 else "large"
print(f"  Trial/Dist  : epsilon^2 = {eps2_trial:.4f}  ({label_trial} effect)")

# ── 6. Power analysis ─────────────────────────────────────────────────────────
print("\n" + "-" * 68)
print("[6] POWER ANALYSIS  (Monte Carlo resampling, 5000 simulations)")
print("-" * 68)

print("\n  [6a] Achieved power with current sample sizes...")
pwr_res   = kruskal_power_achieved([res_groups[r]   for r in RES_ORDER],   n_sim=5000)
pwr_trial = kruskal_power_achieved([trial_groups[t] for t in trial_labels], n_sim=5000)
avg_n_res   = int(np.mean([len(res_groups[r])   for r in RES_ORDER]))
avg_n_trial = int(np.mean([len(trial_groups[t]) for t in trial_labels]))
print(f"  Resolution  : power = {pwr_res:.3f}  (avg n = {avg_n_res} per group)")
print(f"  Trial/Dist  : power = {pwr_trial:.3f}  (avg n = {avg_n_trial} per group)")

print("\n  [6b] Power curve — Resolution effect (n per group vs. power)...")
n_range = list(range(5, 81, 5))
power_curve_res = kruskal_power_vs_n([res_groups[r] for r in RES_ORDER], n_range, n_sim=3000)
n_needed_res, pwr_at_n_res = n_for_target_power(power_curve_res, target=0.80)

print(f"\n  {'N/group':>8}  {'Power':>8}")
print(f"  {'-'*8}  {'-'*8}")
for n_pg, pwr in power_curve_res:
    tag = ""
    if abs(n_pg - avg_n_res) <= 3:
        tag = "  <- current"
    if n_pg == n_needed_res:
        tag = "  <- 80% power target"
    print(f"  {n_pg:>8}  {pwr:>8.3f}{tag}")

if n_needed_res:
    print(f"\n  --> Need ~{n_needed_res} subjects per resolution group "
          f"({n_needed_res * k_res} total) for 80% power.")
else:
    print("\n  --> 80% power not reached within n=5-80 range.")

print("\n  [6c] Power curve — Trial/Distance effect...")
power_curve_trial = kruskal_power_vs_n([trial_groups[t] for t in trial_labels], n_range, n_sim=3000)
n_needed_trial, _ = n_for_target_power(power_curve_trial, target=0.80)
if n_needed_trial:
    print(f"  --> Need ~{n_needed_trial} subjects per distance group "
          f"({n_needed_trial * k_trial} total) for 80% power.")
else:
    print("  --> 80% power not reached within n=5-80 range.")

# ── 7. Results paragraph ──────────────────────────────────────────────────────
print("\n" + "=" * 68)
print("[7] RESULTS SECTION PARAGRAPH  (copy-paste ready)")
print("=" * 68)

def msd(g):
    return f"{np.mean(g):.2f} +/- {np.std(g, ddof=1):.2f}"

sig_pairs = mw_trial_df[mw_trial_df["Sig"] == "*"]
if len(sig_pairs):
